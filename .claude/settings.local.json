{
  "permissions": {
    "allow": [
      "PowerShell(npm install *)",
      "PowerShell(npm run *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5173/)",
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(curl *)",
      "Bash(npm install *)",
      "Bash(NODE_OPTIONS=\"--use-system-ca\" npm install --save-dev typescript@latest @types/node)",
      "Bash(node_modules/.bin/tsc *)",
      "Bash(NODE_OPTIONS=\"--use-system-ca\" node_modules/.bin/tsc -b)",
      "Bash(NODE_OPTIONS=\"--use-system-ca\" npm install --save-dev typescript-eslint@latest)",
      "Bash(NODE_OPTIONS=\"--use-system-ca\" npm uninstall @radix-ui/react-label @radix-ui/react-switch class-variance-authority tailwind-merge)",
      "Bash(echo \"EXIT=$?\")",
      "Bash(tasklist /FI \"IMAGENAME eq node.exe\" /FO TABLE)",
      "PowerShell(Get-Process *)"
    ]
  }
}
